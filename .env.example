# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:ABC...

# --- Google Calendar ---
# Path to the OAuth credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Path where the app stores the OAuth token after first login (auto-created)
GOOGLE_TOKEN_FILE=token.json

# --- App settings ---
TIMEZONE=Europe/Warsaw
OPENAI_MODEL=gpt-4o

# --- User profile (required, JSON) ---
# Single-line JSON wrapped in single quotes. Updated automatically by the bot when you share new info.
# Categories: personal, career, health, diet, lifestyle, relationship, contacts, personality, assistant_preferences
USER_PROFILE='{"personal":{"name":"...","age":0,"location":"..."},"career":{"profession":"...","stack":[],"work_style":"..."}}'
