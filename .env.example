# =============================================================================
# REQUIRED
# =============================================================================

# OpenAI API key — https://platform.openai.com
OPENAI_API_KEY=sk-...

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC...

# Your personal Telegram chat ID — enables all automated daily jobs.
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=123456789

# PostgreSQL connection string — auto-injected by Railway, or set manually for local use.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your initial user profile as a single-line JSON string.
# The bot updates this automatically as it learns more about you.
# Supported categories: personal, career, health, diet, lifestyle,
#   relationship, contacts, personality, assistant_preferences
USER_PROFILE='{"personal":{"name":"...","age":0,"location":"..."},"career":{"profession":"...","stack":[],"work_style":"..."},"health":{"height_cm":0,"weight_kg":0},"lifestyle":{"interests":[]},"personality":{"traits":[]},"assistant_preferences":{"style":"concise, direct, practical"}}'


# =============================================================================
# GOOGLE (Calendar + Tasks)
# =============================================================================

# Path to the OAuth credentials JSON downloaded from Google Cloud Console.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Path where the app stores the OAuth token after first login (auto-created).
GOOGLE_TOKEN_FILE=token.json

# Railway only — paste the full JSON contents of credentials.json here.
# start.sh writes this to disk on each startup (Railway has no persistent filesystem).
GOOGLE_CREDENTIALS_JSON=

# Railway only — paste the full JSON contents of token.json here.
GOOGLE_TOKEN_JSON=


# =============================================================================
# BOT & SERVER
# =============================================================================

# OpenAI model to use.
OPENAI_MODEL=gpt-4o

# IANA timezone for all scheduling and daily jobs.
TIMEZONE=Europe/Warsaw

# Public HTTPS URL of your deployed app — enables webhook mode.
# Leave unset to use polling mode (for local development).
# Example: https://my-app.up.railway.app
WEBHOOK_URL=

# Port the webhook server listens on. Railway injects this automatically.
PORT=8080


# =============================================================================
# LOGGING (optional)
# =============================================================================

# A separate Telegram bot that receives all INFO+ logs in real time.
# Create via @BotFather, start the bot, find its chat ID via:
#   https://api.telegram.org/bot<LOG_BOT_TOKEN>/getUpdates
LOG_BOT_TOKEN=
LOG_CHAT_ID=


# =============================================================================
# DAILY JOB TIMES (optional — all in HH:MM 24h format, uses TIMEZONE)
# =============================================================================

DAILY_MORNING_CHECK_TIME=05:00
DAILY_PROFILE_REVIEW_TIME=23:30
DAILY_ACTIVITY_REVIEW_TIME=23:45
DAILY_SUMMARY_TIME=23:55


# =============================================================================
# RAILWAY PROFILE SYNC (optional)
# =============================================================================
# Keeps USER_PROFILE env var in sync with the database.
# Useful so the profile survives a full DB reset.
# Find these IDs in your Railway project settings / URL.

RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_SERVICE_ID=
